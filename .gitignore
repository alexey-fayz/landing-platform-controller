# ============================================
# Сгенерированные и временные файлы STM32CubeMX / HAL
# ============================================

# CubeMX временные файлы (не включать в репозиторий, кроме .ioc)
*.mxproject
*.ioc.bak
*.ioc.old
*.bak_ioc

# Папки, создаваемые при генерации кода (они пересоздаются из .ioc)
# Если вы всё же храните код в Core/, Drivers/, Middlewares/ – не игнорируйте их.
# Но если вы перегенерируете код, то эти папки будут перезаписаны, поэтому
# рекомендуется не коммитить их, а генерировать заново. Если вы их всё же коммитите,
# закомментируйте следующие строки.
# Core/
# Drivers/
# Middlewares/

# ============================================
# Объектные файлы и артефакты сборки
# ============================================

# Скомпилированные объектные файлы
*.o
*.obj
*.d
*.lst
*.map

# Исполняемые файлы и прошивки
*.elf
*.hex
*.bin
*.axf
*.out

# Статические и динамические библиотеки
*.a
*.lib
*.so
*.dll

# Отладочные символы и файлы трассировки
*.sym
*.trace
*.log

# Папки сборки (для различных IDE)
Debug/
Release/
build/
Build/
Bin/
Output/

